{
	"name": "windows-auto-theme",
	"version": "1.0.0",
	"description": "",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"dev": "electronmon .",
		"less": "less-watch-compiler css css",
		"pack:osx": "electron-packager . --out=builds/packaged --ignore='^/builds' --platform=darwin --arch=x64 --asar --overwrite",
		"pack:win": "electron-packager . --out=builds/packaged --ignore='^/builds' --platform=win32 --arch=ia32,x64 --asar --overwrite",
		"inst:win": "node winstaller.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/demosjarco/Windows-Auto-Theme.git"
	},
	"author": "demosjarco",
	"license": "GPL-3.0-or-later",
	"bugs": {
		"url": "https://github.com/demosjarco/Windows-Auto-Theme/issues"
	},
	"homepage": "https://github.com/demosjarco/Windows-Auto-Theme#readme",
	"dependencies": {
		"dotenv": "^16.0.0",
		"jquery": "^3.6.0"
	},
	"devDependencies": {
		"electron": "^17.1.0",
		"electronmon": "^2.0.2",
		"less-watch-compiler": "^1.16.3"
	},
	"optionalDependencies": {
		"electron-packager": "^15.4.0",
		"electron-winstaller": "^5.0.0"
	}
}
