{
	"name": "windows-auto-theme",
	"version": "1.0.0",
	"description": "Change windows theme based on location daylight or time",
	"main": "main.js",
	"scripts": {
		"reset-deps": "npm un dotenv jquery electron electronmon less-watch-compiler prettier electron-packager electron-winstaller && npm i dotenv jquery && npm i -D electron electronmon less-watch-compiler prettier && npm i -O electron-packager electron-winstaller",
		"prettier": "prettier --check **/*.{js,css,json,md}",
		"prettier:fix": "prettier --write **/*.{js,css,json,md}",
		"format": "npm run prettier",
		"format:fix": "npm run prettier:fix",
		"build": "npm ci --fund=false",
		"start": "electron .",
		"dev": "electronmon .",
		"less": "less-watch-compiler css css",
		"pack:win": "electron-packager . --icon=images/logo/icon.ico --out=builds/packaged --ignore='^/builds' --platform=win32 --arch=ia32,x64 --asar --overwrite",
		"inst:win": "node winstaller.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/demosjarco/Windows-Auto-Theme.git"
	},
	"author": "demosjarco",
	"license": "GPL-3.0-or-later",
	"bugs": {
		"url": "https://github.com/demosjarco/Windows-Auto-Theme/issues"
	},
	"homepage": "https://github.com/demosjarco/Windows-Auto-Theme#readme",
	"dependencies": {
		"dotenv": "^16.0.1",
		"jquery": "^3.6.0"
	},
	"devDependencies": {
		"electron": "^19.0.1",
		"electronmon": "^2.0.2",
		"less-watch-compiler": "^1.16.3",
		"prettier": "^2.6.2"
	},
	"optionalDependencies": {
		"electron-packager": "^15.5.1",
		"electron-winstaller": "^5.0.0"
	}
}
